{
  "packageManager": "npm",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "validate": "bash scripts/validate.sh",
    "test": "bash scripts/test.sh",
    "claude:setup": "bash scripts/setup.sh",
    "claude:validate": "bash scripts/validate.sh",
    "claude:test": "bash scripts/test.sh"
  },
  "claudePlugin": {
    "name": "everything-claude-code",
